<BoxContainer
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Orientation="Vertical" 
    HorizontalExpand="True"
    SeparationOverride="5">
    <BoxContainer Orientation="Horizontal" VerticalExpand="True" SeparationOverride="5" Name="ChatInfo">
        <RichTextLabel Name="Nickname"/>
        <RichTextLabel VerticalExpand="True" Name="ChatEntryInfo"/>
    </BoxContainer>
    <RichTextLabel Name="MessageField"/>
    <BoxContainer Margin="10 0 10 0" Name="FileContainer"/>
</BoxContainer>